# ============================================================
# .env — environment variables for all services
# ============================================================
# SECURITY: This file contains plaintext credentials.
#   - It MUST be listed in .gitignore and never committed to Git.
#   - It is loaded by Docker Compose at runtime via env_file: .env
#   - It is NOT available during "docker build" — only at startup.
#
# To verify it is gitignored: run "git status" and confirm
# this file does NOT appear in the output.
# ============================================================

# ----------------------------------------------------------
# Domain
# ----------------------------------------------------------
# Used by nginx (server_name), WordPress (site URL), and SSL cert CN.
DOMAIN_NAME=mbounoui.42.fr

# ----------------------------------------------------------
# MariaDB
# ----------------------------------------------------------
# DB_NAME    — the database WordPress uses (created by init-db.sh)
# DB_USER    — the application user WordPress connects as
# DB_PASSWORD — that user's password
# DB_ROOT_PASSWORD — MariaDB root password (used only during init)
DB_NAME=wordpress
DB_USER=wpuser
DB_PASSWORD=wpuser_secure_pass_123
DB_ROOT_PASSWORD=root_secure_pass_456

# ----------------------------------------------------------
# WordPress admin account
# ----------------------------------------------------------
# IMPORTANT: WP_ADMIN_USER must NOT contain "admin" or "administrator"
# (case-insensitive). The subject forbids this. "mbounoui" is safe.
WP_ADMIN_USER=mbounoui
WP_ADMIN_PASSWORD=admin_pass_789
WP_ADMIN_EMAIL=admin@mbounoui.42.fr

# ----------------------------------------------------------
# WordPress second user (author)
# ----------------------------------------------------------
# This is the second of the two required WordPress accounts.
# Role "author" means they can write posts but not manage the site.
WP_USER=wpeditor
WP_USER_EMAIL=editor@mbounoui.42.fr
WP_PASSWORD=editor_pass_012

# ----------------------------------------------------------
# FTP server (bonus)
# ----------------------------------------------------------
# These credentials are used by setup-ftp.sh at container startup
# to create an OS user whose home directory is /var/www/html.
# Connect with any FTP client: host=<VM IP>, port=21, passive mode.
FTP_USER=ftpuser
FTP_PASSWORD=ftp_secure_pass_321